# Supabase — copy from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role — SERVER SIDE ONLY. Never prefix with NEXT_PUBLIC_. Never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — SERVER SIDE ONLY. Never prefix with NEXT_PUBLIC_. All AI calls go through /api/ai.
ANTHROPIC_API_KEY=sk-ant-...

# Resend — optional. When set, grade notifications are emailed to students.
# Create a free account at https://resend.com and verify a sending domain.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ChurchCore LMS <noreply@yourdomain.com>

# Public site URL — used in email links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Cron secret — protects /api/digest from unauthorized calls.
# Set the same value in your cron job runner as: Authorization: Bearer <CRON_SECRET>
# With Vercel Cron, add this to env vars; Vercel injects it automatically.
CRON_SECRET=your-random-secret-here
